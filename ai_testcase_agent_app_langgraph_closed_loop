        lg_max_hallu = st.number_input("允许的疑似幻觉用例数", min_value=0, max_value=20, value=0, step=1)
        lg_min_overall = st.slider("最低 LLM Judge 综合分", 0.0, 10.0, 8.0, 0.5)
    if st.button("🚀 一键运行完整 Agent 闭环并生成最终导出", type="primary"):
        if not cfg["api_key"]:
            st.error("请先配置 Ark API Key")
        elif closed_loop_entry.startswith("基于当前") and not cases:
            st.error("当前没有用例。请先在 Tab2 生成初版，或选择“快速生成后闭环/精细生成后闭环”。")
        elif not prd_text.strip() and not st.session_state.get("ui_image_b64"):
            st.error("请先输入 PRD，或上传 UI 图。")
        else:
            status = st.empty()
            def cb(msg: str) -> None:
                status.info(msg)
            with st.spinner("正在运行完整 Agent 闭环..."):
                rag_chunks = [RagChunk(**x) for x in st.session_state.get("rag_chunks", [])]
                if closed_loop_entry.startswith("LangGraph"):
                    cb("正在通过 LangGraph 状态图运行完整 Agent 闭环...")
                    state: AgentState = {
                        "prd_text": prd_text,
                        "guidelines": cfg["guidelines"],
                        "api_key": cfg["api_key"],
                        "model_id": cfg["model_id"],
                        "judge_model_id": cfg["judge_model_id"],
                        "rag_docs": [asdict(x) for x in rag_chunks],
                        "ui_image_b64": st.session_state.get("ui_image_b64"),
                        "ui_image_mime": st.session_state.get("ui_image_mime"),
                        "max_workers": cfg["max_workers"],
                        "enable_semantic_dedup": cfg["use_semantic_dedup"],
                        "max_rounds": lg_max_rounds,
                        "target_coverage": lg_target_coverage,
                        "max_hallucination_cases": int(lg_max_hallu),
                        "min_overall_score": lg_min_overall,
                    }
                    out = run_langgraph_workflow(state)
                else:
                    out = run_unified_agent_closed_loop(
                        closed_loop_entry=closed_loop_entry,
                        prd_text=prd_text,
                        guidelines=cfg["guidelines"],
                        api_key=cfg["api_key"],
                        model_id=cfg["model_id"],
                        judge_model_id=cfg["judge_model_id"],
                        rag_chunks=rag_chunks,
                        current_features=features,
                        current_cases=cases,
                        ui_image_b64=st.session_state.get("ui_image_b64"),
                        ui_image_mime=st.session_state.get("ui_image_mime"),
                        max_workers=cfg["max_workers"],
                        enable_semantic_dedup=cfg["use_semantic_dedup"],
                        progress_callback=cb,
                    )
                st.session_state["features"] = out.get("features", [])
                st.session_state["cases"] = out.get("final_cases", out.get("cases", []))
                st.session_state["eval_result"] = out.get("eval_result")
                st.session_state["coverage_result"] = out.get("coverage_result")
                st.session_state["judge_result"] = out.get("judge_result")
                st.session_state["hallucination_result"] = out.get("hallucination_result")
                if closed_loop_entry.startswith("LangGraph"):
                    st.session_state["last_langgraph_history"] = out.get("history", [])
                st.success(f"完整闭环已完成：{closed_loop_entry}，最终用例与导出文件已更新。")
                st.rerun()

    artifacts = st.session_state.get("export_artifacts") or {}
    if artifacts:
        st.markdown("#### 已生成导出文件")
        d1, d2, d3 = st.columns(3)
        d1.download_button("下载最终 CSV", artifacts.get("csv", b""), file_name="final_testcases.csv", mime="text/csv")
        d2.download_button("下载最终 Markdown", artifacts.get("markdown", b""), file_name="final_testcases.md", mime="text/markdown")
        d3.download_button("下载最终 Excel", artifacts.get("excel", b""), file_name="final_testcases.xlsx", mime="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet")
        st.caption(f"导出生成时间：{st.session_state.get('export_ready_time', '')}")

    if st.session_state.get("last_langgraph_history"):
        with st.expander("LangGraph Agent 执行轨迹", expanded=False):
            st.dataframe(pd.DataFrame(st.session_state["last_langgraph_history"]), use_container_width=True, height=220)

    if not cases:
        st.info("当前还没有测试用例。可以点击上方按钮直接运行完整闭环。")
        return

    metrics = compute_basic_metrics(cases)
    st.session_state["eval_result"] = metrics
    st.markdown("### 规则指标")
    c1, c2, c3, c4, c5 = st.columns(5)
    c1.metric("用例数", metrics["total"])
    c2.metric("格式合规率", f"{metrics['format_rate'] * 100:.1f}%")
    c3.metric("冗余度", f"{metrics['redundancy'] * 100:.1f}%")
    c4.metric("场景丰富度", f"{metrics['type_richness'] * 100:.1f}%")
    c5.metric("严谨度", f"{metrics['risk_score']:.1f}")

    radar_scores = [
        metrics["format_rate"] * 100,
        (1 - metrics["redundancy"]) * 100,
        metrics["type_richness"] * 100,
        metrics["risk_score"],
        100 if metrics["vague_count"] == 0 else max(0, 100 - metrics["vague_count"] * 10),
    ]
    radar_labels = ["格式规范", "冗余控制", "场景丰富", "描述严谨", "模糊词控制"]
    fig = go.Figure()
    fig.add_trace(go.Scatterpolar(r=radar_scores, theta=radar_labels, fill="toself", name="当前版本"))
    fig.update_layout(polar=dict(radialaxis=dict(visible=True, range=[0, 100])), showlegend=False)
    st.plotly_chart(fig, use_container_width=True)

    st.markdown("### 人工基准对齐评测")
    uploaded_gold = st.file_uploader("上传人工用例 CSV / Excel（建议包含 title/steps/expected 列）", type=["csv", "xlsx", "xls"])
    sim_threshold = st.slider("语义匹配阈值", 0.1, 0.9, 0.45, 0.05)
    if st.button("计算人工基准覆盖率 / 精确率 / F1"):
        try:
            human_df = read_uploaded_human_cases(uploaded_gold)
            result = evaluate_against_human_semantic(cases, human_df, threshold=sim_threshold)
            st.session_state["human_eval_result"] = result
            append_version_history("人工基准语义评测", "手动评测", features, cases, metrics, st.session_state.get("coverage_result"), note=f"F1={result.get('f1_score', 0):.1f}%")
            a, b, c = st.columns(3)
            a.metric("覆盖率", f"{result['coverage_score']:.1f}%")
            b.metric("精确率", f"{result['precision_score']:.1f}%")
            c.metric("F1", f"{result['f1_score']:.1f}%")
            st.caption(result.get("comments", ""))
            if result.get("matches"):
                st.dataframe(pd.DataFrame(result["matches"]), use_container_width=True)
        except Exception as e:
            st.error(f"评测失败：{e}")

    st.markdown("### 功能点覆盖检查")
    col_a, col_b = st.columns(2)
    if col_a.button("规则/Embedding 覆盖检查"):
        result = feature_coverage_by_similarity(features, cases)
        st.session_state["coverage_result"] = result
        append_version_history("功能点覆盖检查", "手动评测", features, cases, metrics, coverage_result=result)
        st.success(f"功能点覆盖率：{result['coverage_score'] * 100:.1f}%")
        st.dataframe(pd.DataFrame(result.get("details", [])), use_container_width=True)
    if col_b.button("LLM 覆盖检查"):
        if not cfg["api_key"]:
            st.error("请配置 API Key")
        else:
            with st.spinner("正在调用评审模型..."):
                result = coverage_by_llm(cfg["api_key"], cfg["judge_model_id"], prd_text, features, cases)
                st.session_state["coverage_result"] = result
                append_version_history("LLM覆盖检查", "手动评测", features, cases, metrics, coverage_result=result)
                st.json(result)

    st.markdown("### LLM Judge / 幻觉检查 / 自我修正")
    j1, j2, j3 = st.columns(3)
    if j1.button("🧠 LLM 质量评审"):
        if not cfg["api_key"]:
            st.error("请配置 API Key")
        else:
            with st.spinner("正在评审..."):
                result = judge_by_llm(cfg["api_key"], cfg["judge_model_id"], prd_text, cases)
                st.session_state["judge_result"] = result
                append_version_history("LLM质量评审", "手动评测", features, cases, metrics, st.session_state.get("coverage_result"), judge_result=result)
                st.json(result)
    if j2.button("🧯 疑似幻觉检测"):
        if not cfg["api_key"]:
            st.error("请配置 API Key")
        else:
            with st.spinner("正在检查幻觉..."):
                result = hallucination_check_by_llm(cfg["api_key"], cfg["judge_model_id"], prd_text, cfg["guidelines"], cases)
                st.session_state["hallucination_result"] = result
                append_version_history("疑似幻觉检测", "手动评测", features, cases, metrics, st.session_state.get("coverage_result"), st.session_state.get("judge_result"), hallucination_result=result)
                st.json(result)
    if j3.button("🔁 根据评审结果自动优化"):
        if not cfg["api_key"]:
            st.error("请配置 API Key")
        else:
            with st.spinner("正在优化用例..."):
                new_cases = improve_cases_with_llm(
                    cfg["api_key"], cfg["judge_model_id"], prd_text, cfg["guidelines"], cases,
                    st.session_state.get("judge_result"), st.session_state.get("coverage_result"), st.session_state.get("hallucination_result")
                )
                old_n = len(cases)
                st.session_state["cases"] = semantic_dedup_cases(rule_dedup_cases(new_cases))
                st.session_state["eval_result"] = compute_basic_metrics(st.session_state["cases"])
                st.session_state["coverage_result"] = feature_coverage_by_similarity(features, st.session_state["cases"])
                prepare_export_artifacts(st.session_state["cases"], features, st.session_state["eval_result"])
                append_version_history("手动自我修正并导出", "手动修正", features, st.session_state["cases"], st.session_state["eval_result"], st.session_state.get("coverage_result"), st.session_state.get("judge_result"), st.session_state.get("hallucination_result"), note=f"{old_n} 条 → {len(st.session_state['cases'])} 条")
                st.success(f"优化完成：{old_n} 条 → {len(st.session_state['cases'])} 条，导出文件已更新")
                st.rerun()

    with st.expander("查看当前评审结果 JSON", expanded=False):
        st.write("judge_result")
        st.json(st.session_state.get("judge_result") or {})
        st.write("coverage_result")
        st.json(st.session_state.get("coverage_result") or {})
        st.write("hallucination_result")
        st.json(st.session_state.get("hallucination_result") or {})

    st.markdown("### 版本历史")
    hist = st.session_state.get("history", [])
    if hist:
        st.dataframe(pd.DataFrame(hist), use_container_width=True)
        hist_csv = pd.DataFrame(hist).to_csv(index=False).encode("utf-8-sig")
        st.download_button("下载版本历史 CSV", hist_csv, file_name="version_history.csv", mime="text/csv")
    else:
        st.caption("暂无版本历史。")


def main() -> None:
    st.set_page_config(page_title=APP_NAME, page_icon="🧬", layout="wide", initial_sidebar_state="expanded")
    init_session_state()
    st.title("🧬 智测 AI Agent Pro - PRD 测试用例生成与评测平台")
    st.caption("支持 PRD / 飞书 / UI 图输入，功能点分治生成、RAG、语义评测、LLM Judge、幻觉检测、自我修正和多格式导出。")
    cfg = render_sidebar()
    tab1, tab2, tab3 = st.tabs(["📄 需求输入", "🚀 初版生成 & 可视化", "📊 Agent 闭环评测 & 自我修正"])
    with tab1:
        render_input_tab(cfg)
    with tab2:
        render_generation_tab(cfg)
    with tab3:
        render_eval_tab(cfg)


if __name__ == "__main__":
    main()
